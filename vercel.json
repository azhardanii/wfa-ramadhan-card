{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "arya-ayufam.ucapanlebaran.untukmu.site"
        }
      ],
      "destination": "/arya-ayufam/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "pesandaripinut.untukmu.site"
        }
      ],
      "destination": "/hatfina/$1"
    },
    {
      "source": "/",
      "destination": "/demo/"
    }
  ]
}